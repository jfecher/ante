import Std.Fail.Fail, fail, try, on_fail, assert, ignore_fail, retry_until_success
import Std.C.malloc, free

fail_int {Fail}: I32 = fail ()
ok_int {Fail}: I32 = 7

main () =
    // try:
    println (try ok_int : Maybe I32)   // Some 7
    println (try fail_int : Maybe I32) // None

    // on_fail:
    println (on_fail ok_int do 42)    // 7
    println (on_fail fail_int do 42)  // 42

    // assert:
    // TODO: type error when declaring `{f}` instead of `f`
    ignore_fail fn f ->
        assert true {f}
        println "asserted true"
        assert false {f}
        println "never shown"

    // ignore_fail:
    ignore_fail fail_int
    println "ignored fail"
    ignore_fail ok_int
    println "ignored ok"

    // retry_until_success: counter in heap-allocated U32. Fails twice, then
    // succeeds on the third attempt.
    counter: Ptr U32 = malloc 4
    ptr_store counter 0u32
    val = retry_until_success fn f ->
        n = deref_ptr counter
        ptr_store counter (n + 1)
        if n < 2 then fail () {f}
        n

    println val  // 2
    free counter
    println "done"

// args: --delete-binary --no-color
