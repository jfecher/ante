import Std.Seq
import Std.Seq.Seq, of, pop, remove_last, get, get_copied, iter, push, clone_seq, drop_seq, print_seq, stream_seq
import Std.Stream.iota, stream_fn

type Tag = id: U32

impl drop_tag: Drop Tag with
    drop (t: mut Tag) =
        print "drop "
        println t.id

main () =
    var seq = Seq.empty ()
    seq := seq.push 33
    seq := seq.push 44

    snapshot1 = clone seq

    seq := seq.push 55
    println (clone seq)                      // [33, 44, 55]
    println (clone snapshot1)                // [33, 44]

    println (snapshot1.push 100)             // [33, 44, 100]
    println seq                              // [33, 44, 55]

    // Seq.of:
    // TODO: This type annotation shouldn't be necessary, but is
    built: Seq Usz = Seq.of (iota 5)
    println (clone built)                    // [0, 1, 2, 3, 4]

    // pop:
    popped_seq, popped = pop (clone built)
    println popped                           // Some 4
    println popped_seq                       // [0, 1, 2, 3]

    // remove_last:
    println (remove_last (clone built))      // [0, 1, 2, 3]

    // get:
    match built.get 0
    | Some r -> println (r.* : Usz)
    | None -> println "missing"               // 0

    match built.get 99
    | Some r -> println r.*
    | None -> println "missing"               // missing

    // get_copied:
    println (get_copied built 1u32)    // Some 1

    // Seq.iter:
    iter (ref built) (fn x -> println x.*)   // 0, 1, 2, 3, 4

    // Regression: push fast-path used to silently overwrite the slot at seq.len
    // (Tag 4) and shrink data.len so the orphaned slot (Tag 5) was never visited
    // by drop_data. The fix drops the element at seq.len before reusing the slot
    println "push-overwrite regression:"
    var s = Seq.empty ()
    s := s.push (Tag 1)
    s := s.push (Tag 2)
    s := s.push (Tag 3)
    s := s.push (Tag 4)
    s := s.push (Tag 5)
    var snap = clone s
    s := remove_last s
    s := remove_last s
    Drop.drop (mut snap)                      // direct_rc 2 → 1, seq.len < data.len
    s := s.push (Tag 6)                       // shadow drop fires here: drop 4, drop 5
    Drop.drop (mut s)                         // drops Tag 1, Tag 2, Tag 3, Tag 6

// args: --delete-binary --no-color
// expected stdout:
// [33, 44, 55]
// [33, 44]
// [33, 44, 100]
// [33, 44, 55]
// [0, 1, 2, 3, 4]
// Some 4
// [0, 1, 2, 3]
// [0, 1, 2, 3]
// 0
// missing
// Some 1
// 0
// 1
// 2
// 3
// 4
// push-overwrite regression:
// drop 4
// drop 1
// drop 2
// drop 3
// drop 6
// drop 5

