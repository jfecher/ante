import Std.Vec.Vec, empty, of, is_empty, len, capacity, reserve, push, pop, get, get_unchecked,
    remove_index, remove_first, remove_indices, remove_all, swap_last,
    print_vec, extract_vec, stream_imm_vec, eq_vec

import Std.Fail.on_fail, panic_on_fail
import Std.Stream.iter, stream_array

main () =
    test_basics ()
    test_remove_first ()
    test_remove_indices ()
    test_remove_all ()
    test_swap_last ()
    test_indexing ()
    test_stream ()
    test_eq ()
    test_reverse ()
    test_swap ()
    test_insert ()
    test_dedup ()
    test_truncate_clear ()
    test_sort ()
    test_sort_by ()

test_basics () =
    var v = Vec.empty ()
    println (v.is_empty ())

    v.push 3i32
    v.push 4
    v.push 5
    v.remove_index 1 ~> panic_on_fail
    println (ref v)

    v.pop ()
    println (ref v)

    println ((v.get 0).* ~> on_fail (do 0))
    println (v.is_empty ())
    println (v.len ())
    println (v.capacity () >= v.len ())

    v.reserve 32
    println (v.capacity () >= 32)
    println (v.get_unchecked 0).*

test_remove_first () =
    var v = Vec.empty ()
    v.push 3
    v.push 5
    v.push 5
    println (v.remove_first 5)
    println (ref v)
    println (v.remove_first 99)

test_remove_indices () =
    var v = Vec.of [10, 20, 30, 40, 50]
    idxs = Vec.of [1, 3]
    v.remove_indices idxs ~> panic_on_fail
    println (ref v)

test_remove_all () =
    var v = Vec.of [1, 2, 1, 1, 3]
    println (v.remove_all 1)
    println (ref v)

test_swap_last () =
    var v = Vec.of [10, 20, 30, 40]
    println (v.swap_last 1)
    println (ref v)
    println (v.swap_last 2)

test_indexing () =
    v = Vec.of [10, 40, 30]
    fourty = (ref v).[1]  // TODO: cumbersome
    println fourty

test_stream () =
    v = Vec.of [7, 8, 9]
    iter (imm v) (fn (x: imm I32) -> println x.*)

test_eq () =
    println (Vec.of [1, 2] == Vec.of [1, 2])
    println (Vec.of [1, 2] == Vec.of [1, 3])

test_reverse () =
    var v = Vec.of [1, 2, 3, 4]
    v.reverse ()
    println (ref v)

test_swap () =
    var v = Vec.of [10, 20, 30]
    v.swap 0 2 ~> panic_on_fail
    println (ref v)

test_insert () =
    panic_on_fail do
    var v = Vec.of [1, 3, 5]
    v.insert 1 2
    v.insert 3 4
    println (ref v)

test_dedup () =
    var v = Vec.of [1, 1, 2, 2, 2, 3, 1]
    v.dedup ()
    println (ref v)

test_truncate_clear () =
    var v = Vec.of [1, 2, 3, 4]
    v.truncate 2
    println (ref v)
    Vec.clear (mut v)
    println (ref v)

test_sort () =
    var v = Vec.of [4, 1, 3, 2, 5]
    // `Expected Cmp _ but found Unit` when doing `v.sort ()`
    // TODO: Investigate why this happens for `v.sort ()` but not `v.dedup ()`
    Vec.sort (mut v)
    println (ref v)

test_sort_by () =
    var v = Vec.of [4, 1, 3, 2]
    v.sort_by (>)
    println (ref v)

// args: --delete-binary --no-color
// expected exit status: 101
// expected stderr:
// thread 'main' panicked at src/mir/monomorphization/mod.rs:117:13:
// Monomorphization: no definition for id d80, was monomorphize not given every top-level-item in a single invocation?
// note: run with `RUST_BACKTRACE=1` environment variable to display a backtrace

