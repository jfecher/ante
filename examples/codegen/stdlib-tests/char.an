import Std.Char.is_ascii, is_digit, is_alpha, is_alphanumeric, is_whitespace,
    to_ascii_lower, to_ascii_upper, to_digit

main () =
    println <| is_digit '7'
    println <| is_digit 'z'
    println <| is_alpha 'A'
    println <| is_alpha '7'
    println <| is_alphanumeric 'q'
    println <| is_alphanumeric '!'
    println <| is_whitespace ' '
    println <| is_whitespace '\t'
    println <| is_whitespace 'x'
    println <| is_ascii 'a'
    println <| to_ascii_lower 'X'
    println <| to_ascii_lower 'x'
    println <| to_ascii_upper 'x'
    println <| to_ascii_upper 'X'
    println <| to_digit '5'
    println <| to_digit 'a'

