effect Fail with
    fail: fn Unit -> a

effect Read a with
    read: fn Unit -> a

read_or_none (f: fn {Read Unit} {Fail} -> a): Maybe a =
    handler hf for fail () -> None in
    handler hr for read () -> resume () in
    Maybe.Some (f {hr} {hf})

main () = ()

// args: --delete-binary --no-color
