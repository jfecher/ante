
effect Fail with
    fail: fn Unit -> a

effect Read a with
    read: fn Unit -> a

read_or_none (f: fn {Fail} {Read U32} -> U32) =
    handler hf for fail () -> Maybe.None in
    handler hr for read () -> resume 5u32 in
    Maybe.Some (f {hf} {hr})

foo () {Fail} {Read U32} =
    if false then fail ()
    read ()

main () =
    print <| read_or_none foo

// args: --delete-binary --no-color
// expected stdout: Some 5
