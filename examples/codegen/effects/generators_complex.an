import Std.Stream.iota, enumerate, map, filter, for_, stream_fn_e

main () =
    iota 10
        // TODO: why does filter require an explicit {stream_fn_e}?
        |> filter {stream_fn_e} (fn x -> x.* %% 2usz)
        |> map (_ * 2)
        |> enumerate
        |> for_ println

// args: --delete-binary --no-color
// expected stdout:
// 0, 0
// 1, 4
// 2, 8
// 3, 12
// 4, 16

