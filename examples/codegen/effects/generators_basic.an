import Std.Stream.Emit, emit

iota (n: U32): Unit can Emit U32 = loop (i = 0) ->
    if i < n then
        emit i
        recur (i + 1)

for_ (stream: fn Unit => Unit can Emit a) (f: fn a [env] -> Unit) =
    handler h for emit x ->
        f x
        resume ()
    in stream ()

main () =
    for_ (fn () -> iota 10) print

// args: --delete-binary --no-color
// expected stdout: 0123456789

