foo {Print I32} =
    println "in foo"

foo2 {Print I32} {Print I32} =
    println "in foo2"

// We should allow calling functions like `foo` with only implicit args with a ()
bar {Copy I32} =
    foo ()
    foo2 ()

main () = bar ()

// args: --delete-binary --no-color
// expected stdout:
// in foo
// in foo2
