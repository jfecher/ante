import Std.HashMap.HashMap, empty, of, clear, insert, print_hashmap, remove, get,
    get_entry, stream_map
import Std.Stream.iter, iota, map, stream_fn
import Std.Hash.Hash, hash_u8

main () =
    var map = empty ()

    // Test several inserts. HashMap is linear-scan so it
    // should keep resizing so that it is at least half-empty
    // (ie. its capacity should be >= 2 * its length).
    map.insert 1u8 3u16
    map.insert 2 6
    map.insert 3 9
    map.insert 4 12
    map.insert 5 15
    map.insert 6 18

    map.remove 5
    map.insert 7 21

    // TODO: Fix ref coercion so the explicit `ref` here is unnecessary
    println (ref map)
    println (map.get (ref 3))
    println (get (ref map) (ref 5))

    // get_entry: hit + miss
    match get_entry map (ref 3u8)
    | Some _ -> println "hit"
    | None -> println "missing"

    match get_entry map (ref 99u8)
    | Some _ -> println "hit"
    | None -> println "missing"

    // stream_map impl: build a single-entry map (otherwise ordering isn't deterministic)
    // and stream it
    var single = HashMap.empty ()
    single.insert 42u8 100u16

    var single2 = HashMap.empty ()
    single2.insert 42u8 100u16

    iter single println

    // clear:
    clear (mut single2)
    println (ref single2)

// args: --delete-binary --no-color
