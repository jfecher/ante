import Std.HashMap.HashMap, empty, of, clear, insert, Hash, print_hashmap, remove, get,
    get_entry, stream_map
import Std.Stream.iter, iota, map, stream_fn

impl hash_u8: Hash U8 with
    hash x = cast x

main () =
    var map = empty ()

    // Test several inserts. HashMap is linear-scan so it
    // should keep resizing so that it is at least half-empty
    // (ie. its capacity should be >= 2 * its length).
    map.insert 1u8 3u16
    insert (mut map) 2 6
    insert (mut map) 3 9
    insert (mut map) 4 12
    insert (mut map) 5 15
    insert (mut map) 6 18

    remove (mut map) 5
    insert (mut map) 7 21

    println (ref map)
    println (map.get 3)
    println (get (ref map) 5)

    // get_entry: hit + miss
    match get_entry (ref map) 3u8
    | Some _ -> println "hit"
    | None -> println "missing"

    match get_entry (ref map) 99u8
    | Some _ -> println "hit"
    | None -> println "missing"

    // stream_map impl: build a single-entry map (otherwise ordering isn't deterministic)
    // and stream it
    var single = HashMap.empty ()
    single.insert 42u8 100u16

    var single2 = HashMap.empty ()
    single2.insert 42u8 100u16

    iter single println

    // clear:
    clear (mut single2)
    println (ref single2)

// args: --delete-binary --no-color
// expected stdout:
// [1 -> 3, 2 -> 6, 3 -> 9, 4 -> 12, 6 -> 18, 7 -> 21]
// Some 9
// None
// hit
// missing
// 42, 100
// []
