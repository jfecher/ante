import Std.HashMap.empty, insert, Hash, print_hashmap, remove, get

impl hash_u8: Hash U8 with
    hash x = cast x

main () =
    var map = empty ()

    // Test several inserts. HashMap is linear-scan so it 
    // should keep resizing so that it is at least half-empty 
    // (ie. its capacity should be >= 2 * its length).
    map.insert 1u8 3u16
    insert (mut map) 2 6
    insert (mut map) 3 9
    insert (mut map) 4 12
    insert (mut map) 5 15
    insert (mut map) 6 18

    remove (mut map) 5
    insert (mut map) 7 21

    println (ref map)
    println (map.get 3)
    println (get (ref map) 5)

// args: --delete-binary --no-color
// expected stdout:
// [1 -> 3, 2 -> 6, 3 -> 9, 4 -> 12, 1 -> 18, 7 -> 21]
// Some 9
// None

