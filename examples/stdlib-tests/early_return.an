import Std.EarlyReturn.EarlyReturn, with_early_return, early_return
import Std.Stream.iota, iter, stream_fn

main () =
    // Early return out of a stream consumer
    // FIXME: `r`'s type can't be inferred
    println <| with_early_return fn {r: EarlyReturn Usz} ->
        iter (iota 10) fn x ->
            if x > 3 then early_return x
        0

    // Search for the first index where x == 7; return Some i, or None if not found
    println <| with_early_return fn r ->
        iter (iota 10) fn x ->
            if x == 7 then early_return (Maybe.Some x) {r}
        None

    // Same search but item is missing -> falls through to None
    println <| with_early_return fn r ->
        iter (iota 5) fn x ->
            if x == 99 then early_return (Maybe.Some x) {r}
        None

    // Nested with_early_return: inner returns early but outer should continue
    println <| with_early_return fn ro ->
        inner = with_early_return fn ri ->
            early_return 5 {ri}
            999  // unreachable
        inner + 10  // inner did not abort outer

// args: --delete-binary --no-color
// expected exit status: 101
// expected stderr:
// thread 'main' panicked at src/codegen/llvm/mod.rs:289:22:
// Unsupported instruction in global initializer: Call { function: InstructionResult(InstructionId(0)), arguments: [InstructionResult(InstructionId(3))] }
// note: run with `RUST_BACKTRACE=1` environment variable to display a backtrace

