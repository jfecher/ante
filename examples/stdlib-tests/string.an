import Std.String.bytes, chars, substr, string_of, join, split, reverse
import Std.Stream.iter, intersperse, stream_fn, Emit, emit

// Helper: emit three single-char strings into the Emit String capability.
abc_stream (e: Emit String): Unit =
    e.emit "a"
    e.emit "b"
    e.emit "c"

main () =
    // bytes: emit each byte
    iter (bytes "AB") println

    // chars: emit each character
    iter (chars "AB") println

    // substr: in-bounds + out-of-bounds
    println (substr "abcdef" 1usz 4usz)
    println (substr "abc" 0usz 99usz)
    println "<post-substr>"

    // string_of: round-trip a stream of chars back into a String
    println (string_of (chars "hi"))

    // reverse a string literal (read-only data path) and a heap-built string
    println (reverse "hello")
    fresh = string_of (chars "world")
    println (reverse fresh)

    // split: Emit-effecting function, wrap in a closure to make it a stream.
    iter (fn e -> split "foo bar  baz " c" " {e}) println
    println "<post-split>"

    // join over an interspersed stream → single String "a, b, c"
    println (join (intersperse abc_stream ", "))

// args: --delete-binary --no-color
// expected stdout:
// 65
// 66
// A
// B
// bcd
// 
// <post-substr>
// hi
// olleh
// dlrow
// foo
// bar
// 
// baz
// 
// <post-split>
// a, b, c
