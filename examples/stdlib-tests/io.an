import Std.IO.File, iterator_file
import Std.C.fputs, fopen, fclose

write_test_file (path: String): Unit =
    f = File.open path "w\0"
    f.write "line1\nline2\nline3\n\0"
    f.close ()

main () =
    path = "/tmp/ante_io_test.txt\0"
    write_test_file (clone (ref path))

    // Test next_char reads the first character
    f1 = File.open (clone (ref path)) "r\0"
    c1 = f1.next_char ()
    c2 = f1.next_char ()
    print c1
    println c2
    f1.close ()

    // Test next_line reads complete lines
    f2 = File.open (clone (ref path)) "r\0"
    println (f2.next_line ())
    println (f2.next_line ())
    println (f2.eof ())
    println (f2.next_line ())
    // Iterating past the end should yield an empty string
    println (f2.next_line ())
    println (f2.next_line ())
    println (f2.eof ())
    f2.close ()

    // Test iterating over file lines using the File Iterator impl
    f3 = File.open path "r\0"
    iter (mut f3) println
    f3.close ()

// args: --delete-binary --no-color
// expected stdout:
// li
// line1
// line2
// false
// line3
// 
// 
// true
// line1
// line2
// line3

