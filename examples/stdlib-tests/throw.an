import Std.Throw.Throw, throw, catch, catch_or, catch_or_else, map_err, unwrap_err, Result, Ok, Err
import Std.Fail.Fail, fail, try

print_result (r: Result I32 I32): Unit =
    match r
    | Ok x ->
        print "Ok "
        println x
    | Err e ->
        print "Err "
        println e

main () =
    // catch:
    print_result <| (5 + 2) ~> catch   // Ok 7
    print_result (throw 13 ~> catch)   // Err 13

    // catch_or:
    // Type annotation is needed here to not return Never, `0i32` does not fix it
    println (throw 1 : I32 ~> catch_or 0)  // 0
    println (99 ~> catch_or 0)             // 99

    // catch_or_else:
    println (throw "x" : I32 ~> catch_or_else (fn _s -> 42))  // 42

    // map_err:
    // Can't use `~>` twice since we get 'multiple matching implicits' errors
    print_result (throw 5 _ |> map_err (_ * 10) ~> catch)  // Err 50

    // unwrap_err combined with try
    println (throw 7 ~> unwrap_err ~> try)
    println (try (fn f -> unwrap_err (fn _ -> 0i32) {f}) : Maybe U64)

// args: --delete-binary --no-color
// expected stdout:
// Ok 7
// Err 13
// 0
// 99
// 42
// Err 50
// Some 7
// None
