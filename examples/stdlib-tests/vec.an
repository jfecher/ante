import Std.Vec.Vec, empty, of, is_empty, len, capacity, reserve, push, pop, get, get_unchecked,
    remove_index, remove_first, remove_indices, remove_all, swap_last,
    print_vec, extract_vec, stream_imm_vec, eq_vec

import Std.Fail.try_or
import Std.Stream.iter

main () =
    test_basics ()
    test_remove_first ()
    test_remove_indices ()
    test_remove_all ()
    test_swap_last ()
    test_indexing ()
    test_stream ()
    test_eq ()

test_basics () =
    var v = Vec.empty ()
    println (v.is_empty ())

    v.push 3i32
    v.push 4
    v.push 5
    v.remove_index 1
    println (ref v)

    v.pop ()
    println (ref v)

    println ((v.get 0).* ~> try_or 0)
    println (v.is_empty ())
    println (v.len ())
    println (v.capacity () >= v.len ())

    v.reserve 32
    println (v.capacity () >= 32)
    println (v.get_unchecked 0).*

test_remove_first () =
    var v = Vec.empty ()
    v.push 3
    v.push 5
    v.push 5
    println (v.remove_first 5)
    println (ref v)
    println (v.remove_first 99)

test_remove_indices () =
    var v = Vec.empty ()
    v.push 10
    v.push 20
    v.push 30
    v.push 40
    v.push 50
    var idxs = Vec.empty ()
    idxs.push 1
    idxs.push 3
    v.remove_indices idxs
    println (ref v)

test_remove_all () =
    var v = Vec.empty ()
    v.push 1
    v.push 2
    v.push 1
    v.push 1
    v.push 3
    println (v.remove_all 1)
    println (ref v)

test_swap_last () =
    var v = Vec.empty ()
    v.push 10
    v.push 20
    v.push 30
    v.push 40
    println (v.swap_last 1)
    println (ref v)
    println (v.swap_last 2)

test_indexing () =
    var v = Vec.empty ()
    v.push 10
    v.push 40
    v.push 30
    ten = v.[0]
    println ten

test_stream () =
    var v = Vec.empty ()
    v.push 7
    v.push 8
    v.push 9
    iter (imm v) (fn x -> println x.*)

test_eq () =
    println (vec_of_two 1 2 == vec_of_two 1 2)
    println (vec_of_two 1 2 == vec_of_two 1 3)

vec_of_two (x: I32) (y: I32): Vec I32 =
    var v = Vec.empty ()
    v.push x
    v.push y
    v

// args: --delete-binary --no-color
// expected stdout:
// true
// [3, 5]
// [3]
// 3
// false
// 1
// true
// true
// 3
// Some 1
// [3, 5]
// None
// [10, 30, 50]
// 3
// [2, 3]
// true
// [10, 40, 30]
// false
// 10
// 7
// 8
// 9
// true
// false
