import Std.Stream.iota, map, for_, stream_fn_e

// map and for_ should be tail-resumptive, ensure there is no mention
// of coroutines in the resulting Mir
main () =
    iota 10
        |> map (_ * 3)
        |> for_ println

// Should see no instance of `mco_coro` externs

