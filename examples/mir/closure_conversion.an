main () =
    a = 1
    b = 2
    _c = 3
    free_function x = use x
    captures1 x = use (x, a)
    captures2 x = use (x, a, b)

    captures_closure x = captures2 x

    captures_nested x =
        nested () = a
        use (x, nested ())

    _ = free_function 0
    _ = captures1 0
    _ = captures2 0
    _ = captures_closure 0
    _ = captures_nested 0

use _y = ()

// args: -emir --no-color
// expected stdout:
// extern , d4: fn I32 I32 -> (I32, I32)
// extern use d2: fn (I32, I32) -> Unit
// 
// fn main d0: fn Unit -> Unit
//   b0(b0_0: Unit):
