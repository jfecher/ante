//     | (count: fn Unit -> Unit can Count) () -> fn () (resume: fn Unit [Ptr] -> I32 pure) -> (+: fn I32 I32 {Add I32} [Ptr Unit] -> I32 pure) 1 ((resume: fn Unit [Ptr] -> I32 pure) ()) {(add_i32: Add I32)}
