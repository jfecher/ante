effect Count =
    count: fn Unit -> Unit

foo (): Unit can Count =
    count ()
    repeat 10 fn _ -> count ()

handle_count (f: fn Unit => Unit can Count) =
    handler h for count () -> 1 + resume () in
        f ()
        0

main () =
    handle_count foo
    ()

// args: -e ast-t --no-color
