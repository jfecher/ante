// `print_hashmap` is the `Print (ref HashMap k v)` impl that lives in
// `Std.HashMap` and is not auto-imported by the prelude. Trying to print a
// HashMap without importing it should fail with a suggestion to import it.

import Std.HashMap.empty
import Std.Hash.Hash, hash_u8

main () =
    map = empty ()
    elem = map.get 4 |> Maybe.unwrap
    println (ref elem)

// Found 1 error and 0 warnings

// args: --no-color
// expected exit status: 1
// expected stderr:
// examples/typechecking/missing_implicit_import.an:11:5
// 10 |     elem = map.get 4 |> Maybe.unwrap
//    |     // error: No implicit found for type Print (ref _) required by parameter 2 of println
// 11 |     println (ref elem)
//    |     ^^^^^^^
