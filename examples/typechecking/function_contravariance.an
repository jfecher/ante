// 11 |     use_mut (ref 3)	// error: Argument 1 has type ref I32 but mut I32 was expected
//    |              ^^^^^
// 12 |     needs_mut_fn use_ref
// 
// examples/typechecking/function_contravariance.an:13:18
// 12 |     needs_mut_fn use_ref
//    |     // error: Argument 1 has type fn (mut I32) -> Unit but fn (ref I32) -> Unit was expected
// 13 |     needs_ref_fn use_mut
//    |                  ^^^^^^^
