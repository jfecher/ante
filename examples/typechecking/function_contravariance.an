needs_ref_fn (f: fn (ref I32) -> Unit): Unit = ()

needs_mut_fn (f: fn (mut I32) -> Unit): Unit = ()

use_ref (x: ref I32): Unit = ()

use_mut (x: mut I32): Unit = ()

main () =
    use_ref (mut 3)
    use_mut (ref 3)
    needs_mut_fn use_ref
    needs_ref_fn use_mut

