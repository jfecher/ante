
trait Foo a b =
    foo: fn a -> b

implicit foo_impl: Foo I32 String =
    Foo fn _ -> "hi"

str = foo 0i32

// args: -e ast-t --no-color
// expected stdout:
// type Foo a b =
//     foo: fn a [Ptr Unit] -> b
// 
// implicit (foo_impl: Foo I32 String) =
//     (Foo: fn (fn I32 [Ptr Unit] -> String pure) -> Foo I32 String pure) (fn (_: I32) -> "hi")
// 
// (str: String) = (foo: fn I32 {Foo I32 String} [Ptr Unit] -> String pure) 0_I32 {(foo_impl: Foo I32 String)}

