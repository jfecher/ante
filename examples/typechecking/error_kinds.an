// Specialize error messages to different expr kinds
assignment (_: Unit) : Unit =
    var x = 1i32
    x := "s"

condition (b: I32) : Unit =
    if b then ()

loop_body (b: Bool) (x: I32) : Unit =
    while b do x

array_element (s: String) : Unit =
    _arr = [1i32, s]
    ()

callee (x: I32) : Unit =
    _y = x ()
    ()

returned (x: I32) : I32 =
    if x == 0 then return "s"
    x

s = "str"
function_body (_: Unit) : I32 = s

main () = ()

// args: --check --no-color
// expected exit status: 1
// expected stderr:
