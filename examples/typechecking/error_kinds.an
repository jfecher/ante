// 3 |     var x = 1i32
// 4 |     x := "s"	// error: Cannot assign a value of type String to a target of type I32
//   |          ^^^
// 
// examples/typechecking/error_kinds.an:7:8
// 6 | condition (b: I32) : Unit =
// 7 |     if b then ()	// error: Conditions must have type Bool but this condition has type I32
//   |        ^
// 
// examples/typechecking/error_kinds.an:10:16
//  9 | loop_body (b: Bool) (x: I32) : Unit =
// 10 |     while b do x	// error: Loop bodies must have type Unit but this body has type I32
//    |                ^
// 
// examples/typechecking/error_kinds.an:13:19
// 12 | array_element (s: String) : Unit =
// 13 |     _arr = [1i32, s]	// error: This array element has type String but I32 was expected
//    |                   ^
// 14 |     ()
// 
// examples/typechecking/error_kinds.an:17:10
// 16 | callee (x: I32) : Unit =
// 17 |     _y = x ()	// error: This is called as if it were a fn _ => _ but it has type I32
//    |          ^
// 18 |     ()
// 
// examples/typechecking/error_kinds.an:21:27
// 20 | returned (x: I32) : I32 =
//    |     // error: This returns a value of type String but the enclosing function returns I32
// 21 |     if x == 0 then return "s"
//    |                           ^^^
// 22 |     x
// 
// examples/typechecking/error_kinds.an:25:33
