type Foo a b =
  x: a
  y: b

hello_foo y = Foo with x = "Hello World", y

foo = hello_foo 42

// args: -e ast-t --no-color
// expected stdout:
// type Foo a b =
//     x: a
//     y: b
// 
// (hello_foo: fn _ -> Foo String _ pure) (y: _) = Foo with
//     (x: String) = "Hello World"
//     (y: _) = (y: _)
// 
// (foo: Foo String I32) = (hello_foo: fn I32 -> Foo String I32 pure) 42

