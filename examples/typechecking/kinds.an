// 17 | // Error case: Foo has Kind::Type, applying it to Bool is a kind mismatch
// 18 | bad_app (x: Foo Bool) : Foo Bool = x	// error: Expected 0 arguments but found 1
//    |                         ^^^^^^^^
// 
// examples/typechecking/kinds.an:21:19
// 20 | // Error case: Box has Kind::TypeConstructorSimple(1), not Kind::Type
//    | // error: Expected a type here, this type constructor is missing 1 argument
// 21 | bad_unapplied (x: Box) : Box = x
//    |                   ^^^
