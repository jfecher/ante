// 17 | // Error case: Foo has Kind::Type, applying it to Bool is a kind mismatch
// 18 | bad_app (x: Foo Bool) : Foo Bool = x	// error: Expected 0 arguments but found 1
//    |             ^^^^^^^^
// 
