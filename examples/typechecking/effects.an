effect Log =
    log: fn String -> Unit

effect Use a =
    get: fn Unit -> a
    set: fn a -> Unit

// `log` is handled here; `set` (from a different effect) escapes
handle_basic (): Unit can (Use String) =
    handler h for log v -> set v in
    log "test1"

use_resume () =
    handler h for
      | get () -> resume 3i32
      | set _ -> resume ()
    in ()

does_use (x: I32): Unit can (Use I32) =
    y: I32 = get ()
    set (y + x)

// Ensure a function with unhandled effects errors
pure_fn (): Unit pure =
    log "foo"

// main must always handle all non-primitive effects
main () =
    log "foo"

// args: -e ast-t --no-color
