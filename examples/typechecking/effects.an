//     (y: I32) = (get: fn Unit -> I32 can (Use I32)) ()
//     (set: fn I32 -> Unit can (Use I32)) ((+: fn I32 I32 {Add I32} [Ptr Unit] -> I32 pure) (y: I32) (x: I32) {(add_i32: Add I32)})
