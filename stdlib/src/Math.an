overflowing_add_i8 (x: I8) (y: I8): (I8, Bool) =
    intrinsic "OverflowingAddInt" x y

overflowing_add_i16 (x: I16) (y: I16): (I16, Bool) =
    intrinsic "OverflowingAddInt" x y

