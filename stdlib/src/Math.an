import Std.Fail.Fail, fail_if

export sqrt, sqrtf, cbrt, pow, powf, exp, log, log2, log10,
    sin, cos, tan, asin, acos, atan, atan2,
    floor, ceil, round, trunc, fmod, hypot,
    pi, tau, e, abs,
    CheckedNum, checked_add, checked_sub, checked_mul,
    checked_num_i8, checked_num_i16, checked_num_i32, checked_num_i64, checked_num_isz,
    checked_num_u8, checked_num_u16, checked_num_u32, checked_num_u64, checked_num_usz,
    checked_add_i8, checked_add_i16, checked_add_i32, checked_add_i64, checked_add_isz,
    checked_add_u8, checked_add_u16, checked_add_u32, checked_add_u64, checked_add_usz,
    checked_sub_i8, checked_sub_i16, checked_sub_i32, checked_sub_i64, checked_sub_isz,
    checked_sub_u8, checked_sub_u16, checked_sub_u32, checked_sub_u64, checked_sub_usz,
    checked_mul_i8, checked_mul_i16, checked_mul_i32, checked_mul_i64, checked_mul_isz,
    checked_mul_u8, checked_mul_u16, checked_mul_u32, checked_mul_u64, checked_mul_usz

// Libm wrappers
sqrt = extern "sqrt": fn F64 -> F64
sqrtf = extern "sqrtf": fn F32 -> F32
cbrt = extern "cbrt": fn F64 -> F64

pow = extern "pow": fn F64 F64 -> F64
powf = extern "powf": fn F32 F32 -> F32

exp = extern "exp": fn F64 -> F64
log = extern "log": fn F64 -> F64
log2 = extern "log2": fn F64 -> F64
log10 = extern "log10": fn F64 -> F64

sin = extern "sin": fn F64 -> F64
cos = extern "cos": fn F64 -> F64
tan = extern "tan": fn F64 -> F64
asin = extern "asin": fn F64 -> F64
acos = extern "acos": fn F64 -> F64
atan = extern "atan": fn F64 -> F64
atan2 = extern "atan2": fn F64 F64 -> F64

floor = extern "floor": fn F64 -> F64
ceil = extern "ceil": fn F64 -> F64
round = extern "round": fn F64 -> F64
trunc = extern "trunc": fn F64 -> F64
fmod = extern "fmod": fn F64 F64 -> F64
hypot = extern "hypot": fn F64 F64 -> F64

pi: F64 = 3.141592653589793
tau: F64 = 6.283185307179586
e: F64 = 2.718281828459045

/// Returns the absolute value of this integer
/// Note that `abs MIN` will return `MIN` since there is no corresponding positive integer that fits in the same bit size.
abs (x: t) {n: Num t} {Copy t}: t =
    (<) = n.cmp.(<)
    (-) = n.sub.(-)
    if x < n.zero then n.zero - x else x

checked_add_i8 (x: I8) (y: I8): I8 can Fail =
    result, overflowed = overflowing_add_i8 x y
    fail_if overflowed
    result

checked_add_i16 (x: I16) (y: I16): I16 can Fail =
    result, overflowed = overflowing_add_i16 x y
    fail_if overflowed
    result

/// Add two I32 values, failing on overflow.
checked_add_i32 (x: I32) (y: I32): I32 can Fail =
    result, overflowed = overflowing_add_i32 x y
    fail_if overflowed
    result

