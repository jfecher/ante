import Std.Stream.foldl, stream_fn
import Std.String.bytes

ability Hash t =
    hash: fn t -> U64

// TODO: Proper hash impls
implicit hash_string: Hash String =
    Hash fn s -> U64 (foldl (bytes s) 0 fn acc c -> acc * 10 + c)

implicit hash_u64: Hash U64 =
    Hash fn x -> x

implicit hash_u8: Hash U8 =
    Hash fn x -> cast x
