impl try_cast_i64_u64: TryCast I64 U64 with
    try_cast (x: I64) =
        if x < 0i64 then None
        else Some (transmute x)

impl try_cast_u64: TryCast U64 I64 with
    try_cast (x: U64) =
        if x > 9_223_372_036_854_775_807u64 then None
        else Some (transmute x)

trait Append a with
    (++): fn a a -> a

(++) = Append.(++)

(|>) x f = f x
(<|) f x = f x

trait Extract collection index elem with
    (.[): fn collection index -> elem

(.[) = Extract.(.[)

// TODO: Remove. This breaks ownership
impl extract_ptr_usz: Extract (Ptr t) Usz t with
    (.[) ptr index = deref_ptr <| offset ptr index

// Bitwise functions
// TODO: Move these to separate module
//       Currently this is prevented by the use of 'intrinsic'
//       which is limited to the prelude.

trait Bitwise t with
    band: fn t t -> t
    bor: fn t t -> t
    bxor: fn t t -> t

impl bitwise_i32: Bitwise I32 with
    band x y = intrinsic "BitwiseAnd" x y
    bxor x y = intrinsic "BitwiseXor" x y
    bor x y = intrinsic "BitwiseOr" x y


type Type t = | MkType

size_of (v: Type t): Usz = intrinsic "SizeOf" v

offset (ptr: Ptr t) (index: Usz): Ptr t =
    addr: Usz = transmute ptr
    new_addr = addr + index * size_of (MkType: Type t)
    transmute new_addr

offset_bytes (ptr: Ptr t) (index: Usz): Ptr t =
    addr: Usz = transmute ptr
    transmute (addr + index)

offset_negative (ptr: Ptr t) (index: Usz): Ptr t =
    addr: Usz = transmute ptr
    transmute (addr - index)

// Dereference without a Copy constraint. This is unsafe to use directly
deref (x: ref t): t =
    intrinsic "Deref" x

deref_ptr (p: Ptr t): t =
    deref (transmute p)

ptr_store (p: Ptr a) (value: a): Unit =
    addr: mut a = transmute p
    addr := value

array_insert (p: Ptr a) (index: Usz) (value: a): Unit =
    offset p index |> ptr_store value

ptr_to_mut: fn (Ptr a) -> mut a = transmute

trait Copy t with
    (.*): fn (ref t) -> t

trait Clone t with
    clone: fn (ref t) -> t

clone = Clone.clone

trait Drop t with
    drop: fn (mut t) -> Unit

(.*) = Copy.(.*)

impl copy_i8: Copy I8 with (.*) = deref
impl copy_i16: Copy I16 with (.*) = deref
impl copy_i32: Copy I32 with (.*) = deref
impl copy_i64: Copy I64 with (.*) = deref
impl copy_isz: Copy Isz with (.*) = deref
impl copy_u8: Copy U8 with (.*) = deref
impl copy_u16: Copy U16 with (.*) = deref
impl copy_u32: Copy U32 with (.*) = deref
impl copy_u64: Copy U64 with (.*) = deref
impl copy_usz: Copy Usz with (.*) = deref

impl copy_f32: Copy F32 with (.*) = deref
impl copy_f64: Copy F64 with (.*) = deref

impl copy_unit: Copy Unit with (.*) = deref
impl copy_bool: Copy Bool with (.*) = deref
impl copy_char: Copy Char with (.*) = deref

impl copy_ptr: Copy (Ptr t) with (.*) = deref
impl copy_ref: Copy (ref t) with (.*) = deref
impl copy_mut: Copy (mut t) with (.*) = deref
impl copy_imm: Copy (imm t) with (.*) = deref

impl copy_pair {Copy a} {Copy b}: Copy (a, b) with
    (.*) pair = (pair.first, pair.second)

impl copy_maybe {Copy a}: Copy (Maybe a) with
    (.*) m = match deref m
        | Some x -> Some (x.*)
        | None -> None

impl clone_string: Clone String with
    clone (s: ref String) =
        if s.refcount != null () then
            ptr_store s.refcount (deref_ptr s.refcount + 1)
        deref s

impl drop_string: Drop String with
    drop (s: mut String) =
        if s.refcount != null () then
            count = deref_ptr s.refcount
            if count == 1u32 then
                free (offset_negative s.data (Usz s.offset))
                free s.refcount
            else
                ptr_store s.refcount (count - 1)

null (): Ptr a = transmute 0usz

transmute (x: a): b =
    intrinsic "Transmute" x

// TODO: Special case insertion vs extraction
// trait Insert collection index elem
//     (.[): mut collection - index - elem -> Unit

trait In elem col with
    (in): fn elem col -> Bool

(in) = In.(in)


trait Print t with
    print: fn t -> Unit

print = Print.print

println (x: t) {Print t} =
    Print.print x
    putchar c"\n"

impl print_u8:  Print U8  with print x = print_unsigned (U64 x)
impl print_u16: Print U16 with print x = print_unsigned (U64 x)
impl print_u32: Print U32 with print x = print_unsigned (U64 x)
impl print_u64: Print U64 with print x = print_unsigned x
impl print_usz: Print Usz with print x = print_unsigned (U64 x)

impl print_i8: Print I8 with
    print x = print_signed (I64 x) -128i64 "-128"

impl print_i16: Print I16 with
    print x = print_signed (I64 x) -32_768i64 "-32_768"

impl print_i32: Print I32 with
    print x = print_signed (I64 x) -2_147_483_648i64 "-2_147_483_648"

impl print_i64: Print I64 with
    print x = print_signed x -9_223_372_036_854_775_808i64 "-9_223_372_036_854_775_808"

// TODO: This is broken for non-64-bit platforms.
impl print_isz: Print Isz with
    print x =
        print_signed (I64 x) -9_223_372_036_854_775_808i64 "-9_223_372_036_854_775_808"


impl print_char: Print Char with print x = putchar x

impl print_f64: Print F64 with print = print_float
impl print_f32: Print F32 with print x = print_float (F64 x)

impl print_pair {Print a} {Print b}: Print (a, b) with
    print pair =
        // TODO: Parenthesization for nested pairs while keeping `a, (b, (c, d))` unparenthesized
        print pair.first
        print ", "
        print pair.second

// TODO: temporary, very inaccurate
print_float (f: F64): Unit =
    if f < 0.0 then
        putchar c"-"
        print_float (0.0-f)
    else
        uint = U64 f
        print_unsigned uint
        putchar c"."
        f2 = f - F64 uint
        // Show up to 5 decimal places
        print_unsigned (U64 (f2 * 10_000.0))

impl print_string: Print String with
    print s = loop (i = 0) ->
        if i < s.length then
            off = offset_bytes (s.data) (Usz i)
            c = deref_ptr off
            putchar c
            recur (i + 1)

impl print_maybe {Print a}: Print (Maybe a) with
    print m =
        match m
        | Some a ->
            print "Some "
            // TODO: Parenthesize if necessary
            print a
        | None -> print "None"

impl print_ref {Print a} {Copy a}: Print (ref a) with
    print r = print r.*

// Naive replacement for printf which isn't supported by the cranelift backend
print_unsigned (x: U64): Unit =
    if x >= 10u64 then print_unsigned (x / 10u64)
    digit = x % 10u64 + U64 c"0"
    putchar (Char digit)

print_signed (x: I64) (min: I64) (min_string: String): Unit =
    if x < 0i64 then
        if x == min then
            print min_string
        else
            putchar c"-"
            print_unsigned (Maybe.unwrap (try_cast (0i64 - x)))
    else
        print_unsigned (Maybe.unwrap (try_cast x))

impl print_bool: Print Bool with
    print b =
        if b then print "true"
        else print "false"

trait Iterator it elem with
    next: fn it -> Maybe (it, elem)

iter (iterable: it) f {i: Iterator it elem} =
    match i.next iterable
    | None -> ()
    | Some (rest, elem) ->
        f elem
        iter rest f

type Range t = start: t, end: t

impl iterator_range: Iterator (Range Usz) Usz with
    next range =
        if range.start >= range.end
        then None
        else
            next = Range (range.start + 1) range.end
            Some (next, range.start)

iter_range (from: Usz) (to: Usz) (f: fn Usz [env] -> Unit): Unit =
    iter (Range from to) f

repeat (count: Usz) (f: fn Usz [env] -> Unit): Unit =
    loop (i = 0) ->
        if i < count then
            f i
            recur (i + 1)

impl eq_string: Eq String with
    (==) l r =
        l.length == r.length and
            memcmp l.data r.data (Usz l.length) == 0

impl append_string: Append String with
    (++) s1 s2 =
        if s1.length == 0 then return s2
        if s2.length == 0 then return s1

        len = s1.length + s2.length
        buf = malloc (Usz len + 1usz)

        memcpy buf (s1.data) (Usz s1.length)

        buf_offset = cast (Usz buf + Usz s1.length)

        memcpy buf_offset (s2.data) (Usz s2.length)
        String.from_parts buf len

panic (msg: t) {Print t} =
    print msg
    exit 1
    // Unreachable, return any type
    deref_ptr (null ())

