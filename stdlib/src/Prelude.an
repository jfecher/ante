implicit mul_i8: Mul I8 = Mul fn x y -> intrinsic "MulInt" x y
implicit mul_i16: Mul I16 = Mul fn x y -> intrinsic "MulInt" x y
implicit mul_i32: Mul I32 = Mul fn x y -> intrinsic "MulInt" x y
