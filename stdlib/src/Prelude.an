// x -> Char casts
implicit cast_i8_char: Cast I8 Char   = Cast transmute
implicit cast_i16_char: Cast I16 Char = Cast fn x -> intrinsic "Truncate" x
implicit cast_i32_char: Cast I32 Char = Cast fn x -> intrinsic "Truncate" x
implicit cast_i64_char: Cast I64 Char = Cast fn x -> intrinsic "Truncate" x
implicit cast_isz_char: Cast Isz Char = Cast fn x -> intrinsic "Truncate" x

implicit cast_u8_char: Cast U8 Char   = Cast transmute
implicit cast_u16_char: Cast U16 Char = Cast fn x -> intrinsic "Truncate" x
implicit cast_u32_char: Cast U32 Char = Cast fn x -> intrinsic "Truncate" x
implicit cast_u64_char: Cast U64 Char = Cast fn x -> intrinsic "Truncate" x
implicit cast_usz_char: Cast Usz Char = Cast fn x -> intrinsic "Truncate" x

// Other casts: TODO fill in
implicit cast_i32_usz: Cast I32 Usz = Cast fn x ->
    // TODO: Review. Does this match C?
    transmute (cast x : Isz)

implicit cast_char_i32: Cast Char I32 = Cast fn x -> intrinsic "ZeroExtend" x
implicit cast_char_u64: Cast Char U64 = Cast fn x -> intrinsic "ZeroExtend" x

implicit cast_bool_i32: Cast Bool I32 =
    Cast fn b -> if b then 1 else 0

// TODO: This `Cast I32 String` machinery is temporary. We should unify
// `Cast x String` and `Print x` into a single `Display` ability
count_digits (x: U64): U32 =
    loop x (sum = 1) ->
        if x < 10 then sum
        else recur (x / 10) (sum + 1)

implicit cast_i32_string: Cast I32 String =
    Cast fn x ->
        x = I64 x
        is_neg = x < 0
        abs = if is_neg then 0 - x else x
        var digits: U64 = Maybe.unwrap (try_cast abs)

        var len = count_digits digits
        if is_neg then
            len += 1

        buf: Ptr Char = malloc (Usz len)
        if is_neg then
            ptr_store buf c"-"

        var pos = Usz (len - 1)
        while
            digit = digits % 10 + U64 c"0"
            array_insert buf pos (Char digit)
            digits /= 10
            pos -= 1
            digits > 0
        do ()

        String.from_parts buf len

/// Represents a failable type cast from a to b
ability TryCast a b =
    try_cast: fn a -> Maybe b

implicit try_cast_from_cast {Cast a b}: TryCast a b =
    TryCast fn a -> Some (cast a)


// // Huge block of intrinsic numeric operators incoming
ability Add n = (+): fn n n -> n
implicit add_i8: Add I8 = Add fn x y -> intrinsic "AddInt" x y
implicit add_i16: Add I16 = Add fn x y -> intrinsic "AddInt" x y
implicit add_i32: Add I32 = Add fn x y -> intrinsic "AddInt" x y
implicit add_i64: Add I64 = Add fn x y -> intrinsic "AddInt" x y
implicit add_isz: Add Isz = Add fn x y -> intrinsic "AddInt" x y
implicit add_u8: Add U8 = Add fn x y -> intrinsic "AddInt" x y
implicit add_u16: Add U16 = Add fn x y -> intrinsic "AddInt" x y
implicit add_u32: Add U32 = Add fn x y -> intrinsic "AddInt" x y
implicit add_u64: Add U64 = Add fn x y -> intrinsic "AddInt" x y
implicit add_usz: Add Usz = Add fn x y -> intrinsic "AddInt" x y
implicit add_f32: Add F32 = Add fn x y -> intrinsic "AddFloat" x y
implicit add_f64: Add F64 = Add fn x y -> intrinsic "AddFloat" x y

(+) = Add.(+)
(-) = Sub.(-)
(*) = Mul.(*)
(/) = Div.(/)
(%) = Mod.(%)

