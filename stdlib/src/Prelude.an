impl mul_f64: Mul F64 with (*) x y = intrinsic "MulFloat" x y

trait Div n with (/): fn n n -> n
impl div_i8: Div I8  with (/) x y = intrinsic "DivSigned" x y
impl div_i16: Div I16 with (/) x y = intrinsic "DivSigned" x y
impl div_i32: Div I32 with (/) x y = intrinsic "DivSigned" x y
