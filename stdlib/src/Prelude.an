impl sub_u64: Sub U64 with (-) x y = intrinsic "SubInt" x y
impl sub_usz: Sub Usz with (-) x y = intrinsic "SubInt" x y
impl sub_f32: Sub F32 with (-) x y = intrinsic "SubFloat" x y
impl sub_f64: Sub F64 with (-) x y = intrinsic "SubFloat" x y

trait Mul n with (*): fn n n -> n
impl mul_i8: Mul I8 with (*) x y = intrinsic "MulInt" x y
impl mul_i16: Mul I16 with (*) x y = intrinsic "MulInt" x y
impl mul_i32: Mul I32 with (*) x y = intrinsic "MulInt" x y
impl mul_i64: Mul I64 with (*) x y = intrinsic "MulInt" x y
