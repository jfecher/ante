// Cranelift backend does not support floating-point remainder or modulus


// TODO: We do not have an integer-generic 0 value to use here
(%%) (a: t) (b: t) {Mod t} {Eq t} {Cast U8 t} =
    a % b == cast 0u8


ability Eq t = (==): fn t t -> Bool
implicit eq_i8: Eq I8 with (==) x y = intrinsic "EqInt" x y
implicit eq_i16: Eq I16 with (==) x y = intrinsic "EqInt" x y
implicit eq_i32: Eq I32 with (==) x y = intrinsic "EqInt" x y
implicit eq_i64: Eq I64 with (==) x y = intrinsic "EqInt" x y
implicit eq_isz: Eq Isz with (==) x y = intrinsic "EqInt" x y
implicit eq_u8: Eq U8 with (==) x y = intrinsic "EqInt" x y
implicit eq_u16: Eq U16 with (==) x y = intrinsic "EqInt" x y
implicit eq_u32: Eq U32 with (==) x y = intrinsic "EqInt" x y
implicit eq_u64: Eq U64 with (==) x y = intrinsic "EqInt" x y
implicit eq_usz: Eq Usz with (==) x y = intrinsic "EqInt" x y
implicit eq_f32: Eq F32 with (==) x y = intrinsic "EqFloat" x y
implicit eq_f64: Eq F64 with (==) x y = intrinsic "EqFloat" x y

implicit eq_char: Eq Char with (==) (x: Char) (y: Char): Bool = intrinsic "EqInt" x y
implicit eq_bool: Eq Bool with (==) (x: Bool) (y: Bool): Bool = intrinsic "EqInt" x y

// References are equal if their elements are equal
implicit eq_ref {Eq t}: Eq (ref t) =
    Eq fn l r -> deref l == deref r

// Pointers are equal if their addresses are equal
implicit eq_ptr: Eq (Ptr t) =
    Eq fn l r -> (transmute l : Usz) == transmute r

implicit eq_maybe {Eq e}: Eq (Maybe e) =
    Eq fn l r ->
        match l, r
        | Some lv, Some rv -> lv == rv
        | None, None -> true
        | _ -> false

(==) = Eq.(==)
(!=) (l: t) (r: t) {Eq t} = not (l == r)

ability Not t =
    (not): fn t -> t

(not) = Not.(not)

implicit not_bool: Not Bool =
    Not fn b -> if b then false else true

implicit not_i32: Not I32 =
    Not fn x -> intrinsic "BitwiseNot" x

ability Cmp a =
    (<): fn a a -> Bool

// TODO: Partial ordering screws everything up
(<) = Cmp.(<)
(>) (a: t) (b: t) {Cmp t} = b < a
(<=) (a: t) (b: t) {Cmp t} = not (b < a)
(>=) (a: t) (b: t) {Cmp t} = not (a < b)

implicit cmp_i8: Cmp I8  = Cmp fn x y -> intrinsic "LessSigned" x y
implicit cmp_i16: Cmp I16 = Cmp fn x y -> intrinsic "LessSigned" x y
implicit cmp_i32: Cmp I32 = Cmp fn x y -> intrinsic "LessSigned" x y
implicit cmp_i64: Cmp I64 = Cmp fn x y -> intrinsic "LessSigned" x y
implicit cmp_isz: Cmp Isz = Cmp fn x y -> intrinsic "LessSigned" x y

implicit cmp_u8: Cmp U8  = Cmp fn x y -> intrinsic "LessUnsigned" x y
implicit cmp_u16: Cmp U16 = Cmp fn x y -> intrinsic "LessUnsigned" x y
implicit cmp_u32: Cmp U32 = Cmp fn x y -> intrinsic "LessUnsigned" x y
implicit cmp_u64: Cmp U64 = Cmp fn x y -> intrinsic "LessUnsigned" x y
implicit cmp_usz: Cmp Usz = Cmp fn x y -> intrinsic "LessUnsigned" x y

implicit cmp_f32: Cmp F32 = Cmp fn x y -> intrinsic "LessFloat" x y
implicit cmp_f64: Cmp F64 = Cmp fn x y -> intrinsic "LessFloat" x y

max (l: t) (r: t) {Cmp t} {Copy t}: t = if l > r then l else r
min (l: t) (r: t) {Cmp t} {Copy t}: t = if l < r then l else r


ability Num a =
    add: Add a
    sub: Sub a
    mul: Mul a
    div: Div a
    mod: Mod a
    eq: Eq a
    cmp: Cmp a

implicit num_i8: Num I8 = Num add_i8 sub_i8 mul_i8 div_i8 mod_i8 eq_i8 cmp_i8
implicit num_i16: Num I16 = Num add_i16 sub_i16 mul_i16 div_i16 mod_i16 eq_i16 cmp_i16
implicit num_i32: Num I32 = Num add_i32 sub_i32 mul_i32 div_i32 mod_i32 eq_i32 cmp_i32
implicit num_i64: Num I64 = Num add_i64 sub_i64 mul_i64 div_i64 mod_i64 eq_i64 cmp_i64
implicit num_isz: Num Isz = Num add_isz sub_isz mul_isz div_isz mod_isz eq_isz cmp_isz
implicit num_u8: Num U8 = Num add_u8 sub_u8 mul_u8 div_u8 mod_u8 eq_u8 cmp_u8
implicit num_u16: Num U16 = Num add_u16 sub_u16 mul_u16 div_u16 mod_u16 eq_u16 cmp_u16
implicit num_u32: Num U32 = Num add_u32 sub_u32 mul_u32 div_u32 mod_u32 eq_u32 cmp_u32
implicit num_u64: Num U64 = Num add_u64 sub_u64 mul_u64 div_u64 mod_u64 eq_u64 cmp_u64
implicit num_usz: Num Usz = Num add_usz sub_usz mul_usz div_usz mod_usz eq_usz cmp_usz


implicit try_cast_i64_u64: TryCast I64 U64 =
    TryCast fn (x: I64) ->
        if x < 0i64 then None
        else Some (transmute x)

implicit try_cast_u64: TryCast U64 I64 =
    TryCast fn (x: U64) ->
        if x > 9_223_372_036_854_775_807u64 then None
        else Some (transmute x)

ability Append a =
    (++): fn a a -> a

(++) = Append.(++)

// TODO: This needs to be in the prelude to keep string interpolation working
implicit append_string: Append String =
    Append fn s1 s2 ->
        if s1.length == 0 then return s2
        if s2.length == 0 then return s1

        len = s1.length + s2.length
        buf = malloc (Usz len + 1usz)

        memcpy buf (s1.data) (Usz s1.length)

        buf_offset = cast (Usz buf + Usz s1.length)

        memcpy buf_offset (s2.data) (Usz s2.length)
        String.from_parts buf len

(|>) x f = f x
(<|) f x = f x

ability Extract collection index elem =
    (.[): fn collection index -> elem

(.[) = Extract.(.[)

// TODO: Remove. This breaks ownership
implicit extract_ptr_usz: Extract (Ptr t) Usz t =
    Extract fn ptr index -> deref_ptr <| offset ptr index

// Bitwise functions
// TODO: Move these to separate module
//       Currently this is prevented by the use of 'intrinsic'
//       which is limited to the prelude.

ability Bitwise t =
    band: fn t t -> t
    bor: fn t t -> t
    bxor: fn t t -> t

implicit bitwise_i32: Bitwise I32 = Bitwise
    (fn x y -> intrinsic "BitwiseAnd" x y)
    (fn x y = intrinsic "BitwiseXor" x y)
    (fn x y = intrinsic "BitwiseOr" x y)


type Type t = | MkType

size_of (v: Type t): Usz = intrinsic "SizeOf" v

offset (ptr: Ptr t) (index: Usz): Ptr t =
    addr: Usz = transmute ptr
    new_addr = addr + index * size_of (MkType: Type t)
    transmute new_addr

offset_bytes (ptr: Ptr t) (index: Usz): Ptr t =
    addr: Usz = transmute ptr
    transmute (addr + index)

offset_negative (ptr: Ptr t) (index: Usz): Ptr t =
    addr: Usz = transmute ptr
    transmute (addr - index)

// Dereference without a Copy constraint. This is unsafe to use directly
deref (x: ref t): t =
    intrinsic "Deref" x

deref_ptr (p: Ptr t): t =
    deref (transmute p)

ptr_store (p: Ptr a) (value: a): Unit =
    addr: mut a = transmute p
    addr := value

array_insert (p: Ptr a) (index: Usz) (value: a): Unit =
    offset p index |> ptr_store value

ptr_to_mut: fn (Ptr a) -> mut a = transmute

ability Copy t =
    (.*): fn (ref t) -> t

ability Clone t =
    clone: fn (ref t) -> t

ability Drop t =
    drop: fn (mut t) -> Unit

implicit copy_i8: Copy I8 = Copy deref
implicit copy_i16: Copy I16 = Copy deref
implicit copy_i32: Copy I32 = Copy deref
implicit copy_i64: Copy I64 = Copy deref
implicit copy_isz: Copy Isz = Copy deref
implicit copy_u8: Copy U8 = Copy deref
implicit copy_u16: Copy U16 = Copy deref
implicit copy_u32: Copy U32 = Copy deref
implicit copy_u64: Copy U64 = Copy deref
implicit copy_usz: Copy Usz = Copy deref

implicit copy_f32: Copy F32 = Copy deref
implicit copy_f64: Copy F64 = Copy deref

implicit copy_unit: Copy Unit = Copy deref
implicit copy_bool: Copy Bool = Copy deref
implicit copy_char: Copy Char = Copy deref

implicit copy_ptr: Copy (Ptr t) = Copy deref
implicit copy_ref: Copy (ref t) = Copy deref
implicit copy_mut: Copy (mut t) = Copy deref
implicit copy_imm: Copy (imm t) = Copy deref

implicit copy_pair {Copy a} {Copy b}: Copy (a, b) =
    Copy fn pair -> (pair.first, pair.second)

implicit copy_maybe {Copy a}: Copy (Maybe a) =
    Copy fn m -> match deref m
        | Some x -> Some (x.*)
        | None -> None

implicit clone_string: Clone String =
    Clone fn (s: ref String) ->
        if s.refcount != null () then
            ptr_store s.refcount (deref_ptr s.refcount + 1)
        deref s

implicit drop_string: Drop String =
    Drop fn (s: mut String) ->
        if s.refcount != null () then
            count = deref_ptr s.refcount
            if count == 1u32 then
                free (offset_negative s.data (Usz s.offset))
                free s.refcount
            else
                ptr_store s.refcount (count - 1)

null (): Ptr a = transmute 0usz

transmute (x: a): b =
    intrinsic "Transmute" x

// TODO: Special case insertion vs extraction
// ability Insert collection index =
//     (.[): mut collection - index - elem -> Unit

ability Print t =
    print: fn t -> Unit

println (x: t) {Print t} =
    Print.print x
    putchar c"\n"

implicit print_u8:  Print U8  = Print fn x -> print_unsigned (U64 x)
implicit print_u16: Print U16 = Print fn x -> print_unsigned (U64 x)
implicit print_u32: Print U32 = Print fn x -> print_unsigned (U64 x)
implicit print_u64: Print U64 = Print fn x -> print_unsigned x
implicit print_usz: Print Usz = Print fn x -> print_unsigned (U64 x)

implicit print_i8: Print I8 =
    Print fn x -> print_signed (I64 x) -128i64 "-128"

implicit print_i16: Print I16 =
    Print fn x -> print_signed (I64 x) -32_768i64 "-32_768"

implicit print_i32: Print I32 =
    Print fn x -> print_signed (I64 x) -2_147_483_648i64 "-2_147_483_648"

implicit print_i64: Print I64 =
    Print fn x -> print_signed x -9_223_372_036_854_775_808i64 "-9_223_372_036_854_775_808"

// TODO: This is broken for non-64-bit platforms.
implicit print_isz: Print Isz =
    Print fn x ->
        print_signed (I64 x) -9_223_372_036_854_775_808i64 "-9_223_372_036_854_775_808"


implicit print_char: Print Char = Print fn x -> putchar x

implicit print_f64: Print F64 = Print print_float
implicit print_f32: Print F32 = Print fn x -> print_float (F64 x)

implicit print_pair {Print a} {Print b}: Print (a, b) =
    Print fn pair ->
        // TODO: Parenthesization for nested pairs while keeping `a, (b, (c, d))` unparenthesized
        print pair.first
        print ", "
        print pair.second

// TODO: temporary, very inaccurate
print_float (f: F64): Unit =
    if f < 0.0 then
        putchar c"-"
        print_float (0.0-f)
    else
        uint = U64 f
        print_unsigned uint
        putchar c"."
        f2 = f - F64 uint
        // Show up to 5 decimal places
        print_unsigned (U64 (f2 * 10_000.0))

implicit print_string: Print String =
    Print fn s -> loop (i = 0) ->
        if i < s.length then
            off = offset_bytes (s.data) (Usz i)
            c = deref_ptr off
            putchar c
            recur (i + 1)

implicit print_maybe {Print a}: Print (Maybe a) =
    Print fn m ->
        match m
        | Some a ->
            print "Some "
            // TODO: Parenthesize if necessary
            print a
        | None -> print "None"

implicit print_ref {Print a} {Copy a}: Print (ref a) =
    Print fn r -> print r.*

// Naive replacement for printf which isn't supported by the cranelift backend
print_unsigned (x: U64): Unit =
    if x >= 10u64 then print_unsigned (x / 10u64)
    digit = x % 10u64 + U64 c"0"
    putchar (Char digit)

print_signed (x: I64) (min: I64) (min_string: String): Unit =
    if x < 0i64 then
        if x == min then
            print min_string
        else
            putchar c"-"
            print_unsigned (Maybe.unwrap (try_cast (0i64 - x)))
    else
        print_unsigned (Maybe.unwrap (try_cast x))

implicit print_bool: Print Bool =
    Print fn b ->
        if b then print "true"
        else print "false"

ability Iterator it elem =
    next: fn it -> Maybe (it, elem)

iter (iterable: it) f {i: Iterator it elem} =
    match i.next iterable
    | None -> ()
    | Some (rest, elem) ->
        f elem
        iter rest f

type Range t = start: t, end: t

implicit iterator_range: Iterator (Range Usz) Usz =
    Iterator fn range ->
        if range.start >= range.end
        then None
        else
            next = Range (range.start + 1) range.end
            Some (next, range.start)

iter_range (from: Usz) (to: Usz) (f: fn Usz => Unit): Unit =
    iter (Range from to) f

repeat (count: Usz) (f: fn Usz => Unit): Unit =
    loop (i = 0) ->
        if i < count then
            f i
            recur (i + 1)

panic (msg: t) {Print t} =
    print msg
    exit 1
    // Unreachable, return any type
    deref_ptr (null ())

ignore _x = ()
