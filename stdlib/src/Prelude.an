type String =
    data: Ptr Char
    refcount: Ptr U32
    length: U32
    // Substrings store their offset into the original string for use when freeing them later
    offset: U32

// Construct a fresh, unaliased string from an owned pointer to characters and a length.
String.from_parts (pointer: Ptr Char) (length: U32): String =
    rc: Ptr U32 = malloc 4
    ptr_store rc 1
    String pointer rc length 0

type Maybe t =
   | None
   | Some t

Maybe.unwrap (m: Maybe t): t =
    match m
    | Some x -> x
    | None -> panic "Tried to unwrap a None value"

Maybe.unwrap_or_else (m: Maybe t) (f: fn Unit => t): t =
    match m
    | Some x -> x
    | None -> f ()

type Result t e =
   | Ok t
   | Error e

type (,) a b = first: a, second: b

first (a, _) = a
second (_, b) = b
third (_, _, c) = c
fourth (_, _, _, d) = d
fifth (_, _, _, _, e) = e

/// A type conversion from a to b
ability Cast a b =
    cast: fn a -> b

cast = Cast.cast

implicit cast_same: Cast a a =
    Cast fn a -> a

implicit cast_ptr_usz: Cast (Ptr a) Usz =
    Cast fn ptr -> transmute ptr

implicit cast_usz_ptr: Cast Usz (Ptr a) =
    Cast fn address -> transmute address

